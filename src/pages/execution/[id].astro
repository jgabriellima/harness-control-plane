---
import ExecutionView from '../../components/react/ExecutionView';
import OrchestrationLayout from '../../layouts/OrchestrationLayout.astro';

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/');
}
---

<OrchestrationLayout
  title={`Execution ${id}`}
  description="Business Runtime execution visibility."
  projectName="Business Runtime"
>
  <div class="flex min-h-0 flex-1 flex-col overflow-hidden">
    <ExecutionView client:load executionId={id} />
  </div>
</OrchestrationLayout>
