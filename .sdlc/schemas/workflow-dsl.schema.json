{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sdlc.jambu/schemas/workflow-dsl",
  "title": "WorkflowDSL",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": { "const": "sdlc.jambu/v1" },
    "kind": { "const": "Workflow" },
    "metadata": {
      "type": "object",
      "required": ["id", "name", "version", "trigger"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "trigger": { "type": "string", "pattern": "^/[a-z0-9:-]+$" },
        "command": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["triggers", "stateContract", "nodes"],
      "additionalProperties": false,
      "properties": {
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": false,
            "properties": {
              "type": { "enum": ["command", "schedule", "webhook", "workflow_dispatch"] },
              "command": { "type": "string" },
              "schedule": { "type": "string" }
            }
          }
        },
        "stateContract": { "type": "string" },
        "cognitiveOutputContract": {
          "type": "string",
          "default": "schemas/cognitive-output.schema.json"
        },
        "runOutputContract": { "type": "string" },
        "preConditions": { "type": "array", "items": { "type": "string" } },
        "successCriteria": { "type": "array", "items": { "type": "string" } },
        "failureBehavior": { "type": "array", "items": { "type": "string" } },
        "bootstrapCheck": {
          "type": "object",
          "properties": {
            "triggerCondition": { "type": "string" },
            "message": { "type": "string" }
          }
        },
        "orchestration": {
          "type": "object",
          "description": "E2E orchestration extensions — manifest, modes, composition",
          "additionalProperties": true
        },
        "scopes": { "type": "object", "additionalProperties": true },
        "rollbackProcedure": { "type": "object" },
        "severitySla": { "type": "object" },
        "completion": { "type": "object" },
        "agentPolicy": {
          "type": "object",
          "description": "Normative agent contract for slash-triggered workflows — not conversational",
          "additionalProperties": true,
          "properties": {
            "controlPlane": { "type": "string" },
            "conflictPolicy": { "enum": ["ask", "reuse", "force_new_run"] },
            "completionPolicy": { "enum": ["deterministic", "hitl"] },
            "orchestratorRole": { "type": "string" },
            "implementationDelegate": { "type": "string" },
            "mandatoryFirstCommands": { "type": "array", "items": { "type": "string" } },
            "stepLoop": { "type": "array", "items": { "type": "string" } },
            "forbiddenAgentBehaviors": { "type": "array", "items": { "type": "string" } },
            "onCompleteRequiredActions": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/node" }
        }
      }
    }
  },
  "$defs": {
    "control": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blocking": { "type": "boolean" },
        "onFailure": {
          "type": "string",
          "enum": [
            "abort",
            "return_to_planning",
            "return_to_implementation",
            "return_to_fix_implementation",
            "return_to_context_hydration",
            "escalate_to_architect",
            "trigger_rollback",
            "warn_and_continue",
            "fix_and_retry"
          ]
        },
        "skipInModes": { "type": "array", "items": { "type": "string" } },
        "condition": { "type": "string" },
        "hitl": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "reason"],
          "properties": {
            "kind": { "enum": ["input", "approval", "external"] },
            "reason": { "type": "string", "minLength": 1 },
            "resumeGate": { "type": "string" }
          }
        }
      }
    },
    "emitRef": {
      "type": "object",
      "required": ["key", "from"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "from": { "type": "string", "minLength": 1 }
      }
    },
    "node": {
      "$ref": "#/$defs/compositeNode"
    },
    "compositeNode": {
      "type": "object",
      "required": ["id", "function", "postCondition"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "dependsOn": { "type": "array", "items": { "type": "string" } },
        "function": {
          "type": "object",
          "required": ["invoke"],
          "properties": {
            "invoke": { "$ref": "#/$defs/invoke" },
            "objective": { "type": "string" },
            "outputSchema": { "type": "string" },
            "inputs": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "playbookRef": {
                  "type": "string",
                  "description": "Domain playbook id for playbook-capability skill nodes"
                }
              }
            }
          }
        },
        "preCondition": { "$ref": "#/$defs/condition" },
        "postCondition": { "$ref": "#/$defs/condition" },
        "control": { "$ref": "#/$defs/control" },
        "emits": {
          "type": "array",
          "items": { "$ref": "#/$defs/emitRef" }
        },
        "workflowRef": { "type": "string" },
        "protocolGates": { "type": "array", "items": { "type": "string" } }
      }
    },
    "invoke": {
      "type": "object",
      "required": ["type", "ref"],
      "properties": {
        "type": { "enum": ["command", "agent", "subprocess", "skill"] },
        "ref": { "type": "string" },
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "step": { "type": "string" }
      }
    },
    "condition": {
      "type": "object",
      "required": ["target", "checks"],
      "properties": {
        "target": { "type": "string" },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/check" }
        }
      }
    },
    "check": {
      "type": "object",
      "properties": {
        "type": { "enum": ["schema", "assert", "filesystem", "script", "ref"] },
        "schema": { "type": "string" },
        "path": { "type": "string" },
        "eq": {},
        "ref": { "type": "string" },
        "inputs": { "type": "object" },
        "required": { "type": "array", "items": { "type": "string" } },
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
