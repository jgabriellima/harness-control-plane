{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jambu.ai/schemas/sdlc/credential-manifest.schema.json",
  "title": "SDLC Credential Manifest",
  "description": "Generated union of secrets_required from active integrations. Values live in layer-specific .env files, never in this manifest.",
  "type": "object",
  "required": ["generated_at", "secrets"],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when manifest was built"
    },
    "source": {
      "type": "string",
      "enum": ["init", "config-add", "config-swap", "config-remove", "doctor-regen"],
      "description": "Pipeline entry point that produced this manifest"
    },
    "secrets": {
      "type": "array",
      "items": { "$ref": "#/$defs/secretEntry" }
    }
  },
  "$defs": {
    "secretScope": {
      "type": "string",
      "enum": ["local", "ci", "both"]
    },
    "secretLayer": {
      "type": "string",
      "enum": ["sdlc", "app", "ci", "runtime"],
      "description": "sdlc=.sdlc/.env, app={target_root}/.env, ci=gh secret instructions, runtime=IDE/MCP docs"
    },
    "slotId": {
      "type": "string",
      "enum": [
        "work_items",
        "source_control",
        "ci",
        "qa",
        "observability",
        "deploy",
        "post_deploy",
        "incident"
      ]
    },
    "secretEntry": {
      "type": "object",
      "required": ["env_var", "scope", "layer", "integration", "slot"],
      "additionalProperties": false,
      "properties": {
        "env_var": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "scope": { "$ref": "#/$defs/secretScope" },
        "layer": { "$ref": "#/$defs/secretLayer" },
        "integration": {
          "type": "string",
          "description": "Provider id from integration catalog (e.g. plane, vercel)"
        },
        "slot": { "$ref": "#/$defs/slotId" },
        "required": {
          "type": "boolean",
          "default": true,
          "description": "When false, integration may remain pending_credentials"
        },
        "description": { "type": "string" }
      }
    }
  },
  "examples": [
    {
      "generated_at": "2026-05-24T00:00:00Z",
      "source": "init",
      "secrets": [
        {
          "env_var": "PLANE_API_KEY",
          "scope": "local",
          "layer": "sdlc",
          "integration": "plane",
          "slot": "work_items",
          "required": true,
          "description": "Plane API key for ticket operations"
        },
        {
          "env_var": "PUBLIC_POSTHOG_KEY",
          "scope": "both",
          "layer": "app",
          "integration": "posthog",
          "slot": "observability",
          "required": true
        },
        {
          "env_var": "VERCEL_TOKEN",
          "scope": "ci",
          "layer": "ci",
          "integration": "vercel",
          "slot": "deploy",
          "required": true
        }
      ]
    }
  ]
}
