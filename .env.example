# Control plane local env — copy to .env and adjust paths

# Bound workspace for platform dev (must contain .cursor/runtime-binding.yaml)
CONTROL_PLANE_PLATFORM_ROOT=../business-workflow/app

# Optional: product repo used for {repo}/workspaces/ layout
CONTROL_PLANE_HOST_REPO=../business-workflow

# Workspace container override (default: ~/jambu/workspaces/ or {host}/workspaces/)
# CONTROL_PLANE_WORKSPACES_ROOT=~/jambu/workspaces

# Cursor SDK (runtime chat)
# CURSOR_API_KEY=

# Observability (ADR-044)
# CONTROL_PLANE_LOG_LEVEL=debug
# CONTROL_PLANE_DISPATCH_TIMEOUT_MS=120000
# SENTRY_DSN=
